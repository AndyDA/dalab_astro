<form id='subscribe-form' class='listmonk-form'>
  <div>
    <h3>Subscribe to our newsletter</h3>

    <p><input type='email' name='email' id='email' required placeholder='E-mail' /></p>
    <p><input type='text' name='name' id='name' placeholder='Name (optional)' /></p>

    <input type='hidden' name='list_id' value='402eb8c4-563a-49ff-8910-bfca103ffd56' />

    <button type='submit'>Subscribe</button>
  </div>
</form>

<script>
  // Configuration
  const LISTMONK_URL = 'https://sub.dalab.top';
  const LIST_UUID = '402eb8c4-563a-49ff-8910-bfca103ffd56';

  // Helper function to validate email
  function isValidEmail(email: string): boolean {
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    return emailRegex.test(email);
  }

  // Helper function to clear previous messages
  function clearPreviousMessage(id: string) {
    const messageElement = document.getElementById(id);
    if (messageElement) {
      messageElement.remove();
    }
  }

  // Helper function to add message element
  function addMessageElement(message: string, type: 'error' | 'success', element: HTMLElement) {
    const p = document.createElement('p');
    p.id = 'message';
    p.className = `message ${type === 'success' ? 'text-green-600' : 'text-red-600'} mt-2 px-2 font-medium`;
    p.innerText = message;
    element.appendChild(p);
  }

  // Helper function to clear input
  function clearInput(id: string) {
    const input = document.getElementById(id) as HTMLInputElement;
    if (input) input.value = '';
  }

  // Send subscription to Listmonk
  async function subscribeToListmonk(email: string, name: string) {
    const response = await fetch(`${LISTMONK_URL}/api/public/subscription`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({
        email: email,
        name: name || '',
        list_uuids: [LIST_UUID],
      }),
    });

    if (!response.ok) {
      const text = await response.text();
      throw new Error(`HTTP ${response.status}: ${text}`);
    }

    const contentType = response.headers.get('content-type');
    if (contentType && contentType.includes('application/json')) {
      return await response.json();
    } else {
      const text = await response.text();
      throw new Error('Expected JSON response but got HTML');
    }
  }

  // Get form element
  const form = document.getElementById('subscribe-form') as HTMLFormElement;

  // Handle form submission
  async function handleFormSubmit(e: Event) {
    e.preventDefault();

    const formData = new FormData(form);
    const email = (formData.get('email') as string).trim();
    const name = (formData.get('name') as string)?.trim() || '';

    clearPreviousMessage('message');

    // Validate email
    if (!email) {
      addMessageElement('Email is required.', 'error', form);
      return;
    }

    if (!isValidEmail(email)) {
      addMessageElement('Please enter a valid email address.', 'error', form);
      return;
    }

    // Disable button during submission
    const submitButton = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const originalText = submitButton.innerText;
    submitButton.disabled = true;
    submitButton.innerText = 'Subscribing...';

    try {
      const result = await subscribeToListmonk(email, name);

      addMessageElement('Successfully subscribed! Check your email to confirm.', 'success', form);
      clearInput('email');
      clearInput('name');
    } catch (error: any) {
      console.error('Subscription error:', error);

      const errorMessage = error.message?.includes('already')
        ? 'This email is already subscribed.'
        : 'An error occurred. Please try again later.';

      addMessageElement(errorMessage, 'error', form);
    } finally {
      // Re-enable button
      submitButton.disabled = false;
      submitButton.innerText = originalText;
    }
  }

  // Add event listener
  if (form) {
    form.addEventListener('submit', handleFormSubmit);
  }
</script>

<style>
  .listmonk-form {
    max-width: 500px;
    margin: 0 auto;
  }

  .listmonk-form div {
    padding: 1.5rem;
    border-radius: 8px;
    background-color: #f9fafb;
    border: 1px solid #e5e7eb;
  }

  .listmonk-form h3 {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: #1f2937;
  }

  .listmonk-form input[type='email'],
  .listmonk-form input[type='text'] {
    width: 100%;
    padding: 0.75rem;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    font-size: 0.875rem;
    transition: border-color 0.2s;
  }

  .listmonk-form input:focus {
    outline: none;
    border-color: #3b82f6;
    ring: 2px;
    ring-color: rgba(59, 130, 246, 0.1);
  }

  .listmonk-form button {
    width: 100%;
    padding: 0.75rem;
    background-color: #3b82f6;
    color: white;
    border: none;
    border-radius: 6px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.2s;
  }

  .listmonk-form button:hover {
    background-color: #2563eb;
  }

  .listmonk-form button:active {
    background-color: #1d4ed8;
  }

  .listmonk-form p {
    margin: 0.75rem 0;
  }

  .message {
    padding: 0.75rem;
    border-radius: 6px;
    margin-top: 1rem;
  }

  .text-green-600 {
    background-color: #dcfce7;
    color: #16a34a;
  }

  .text-red-600 {
    background-color: #fee2e2;
    color: #dc2626;
  }
</style>
