<iframe name='hidden_iframe' id='hidden_iframe' style='display:none;'></iframe>

<form
  id='subscribe-form'
  action='https://sub.dalab.top/subscription/form'
  method='POST'
  class='listmonk-form'
  target='hidden_iframe'
>
  <div>
    <h3>Subscribe to our newsletter</h3>

    <p><input type='email' name='email' id='email' required placeholder='E-mail' /></p>
    <p><input type='text' name='name' id='name' placeholder='Name (optional)' /></p>

    <input type='hidden' name='l' value='402eb8c4-563a-49ff-8910-bfca103ffd56' />

    <button type='submit'>Subscribe</button>

    <div id='message-container'></div>
  </div>
</form>

<script>
  const form = document.getElementById('subscribe-form') as HTMLFormElement;
  const messageContainer = document.getElementById('message-container') as HTMLElement;

  form.addEventListener('submit', function () {
    const submitButton = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    submitButton.disabled = true;
    submitButton.innerText = 'Subscribing...';

    // Show success message after a short delay
    setTimeout(() => {
      messageContainer.innerHTML =
        '<p class="message success">Successfully subscribed! Check your email to confirm.</p>';
      submitButton.disabled = false;
      submitButton.innerText = 'Subscribe';
      form.reset();
    }, 2000);
  });
</script>

<style>
  .listmonk-form {
    max-width: 500px;
    margin: 0 auto;
  }

  .listmonk-form div {
    padding: 1.5rem;
    border-radius: 8px;
    background-color: #f9fafb;
    border: 1px solid #e5e7eb;
  }

  .listmonk-form h3 {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: #1f2937;
  }

  .listmonk-form input[type='email'],
  .listmonk-form input[type='text'] {
    width: 100%;
    padding: 0.75rem;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    font-size: 0.875rem;
    transition: border-color 0.2s;
  }

  .listmonk-form input:focus {
    outline: none;
    border-color: #3b82f6;
    ring: 2px;
    ring-color: rgba(59, 130, 246, 0.1);
  }

  .listmonk-form button {
    width: 100%;
    padding: 0.75rem;
    background-color: #3b82f6;
    color: white;
    border: none;
    border-radius: 6px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.2s;
  }

  .listmonk-form button:hover {
    background-color: #2563eb;
  }

  .listmonk-form button:active {
    background-color: #1d4ed8;
  }

  .listmonk-form p {
    margin: 0.75rem 0;
  }

  .message {
    padding: 0.75rem;
    border-radius: 6px;
    margin-top: 1rem;
  }

  .message.success {
    background-color: #dcfce7;
    color: #16a34a;
  }

  .message.error {
    background-color: #fee2e2;
    color: #dc2626;
  }
</style>
