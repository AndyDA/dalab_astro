---
import CallToAction from '~/components/widgets/CallToAction.astro';
import Content from '~/components/widgets/Content.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Steps from '~/components/widgets/Steps.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Drupal Development — Fast. Scalable. No bullshit.',
  description:
    'We build Drupal platforms that actually perform. Clean architecture. Minimal frontend. Zero unnecessary complexity.',
};
---

<Layout metadata={metadata}>
  <!-- Hero ******************* -->

  <Hero
    tagline='Drupal Development'
    title='Fast. Scalable.<br />No bullshit.'
    subtitle='We build Drupal platforms that actually perform. Clean architecture. Minimal frontend. Zero unnecessary complexity. If your project needs speed, structure, and long-term stability — this is it.'
    actions={[
      { variant: 'primary', text: 'Get Estimate', href: '/contact' },
      { text: 'Book a Call', href: '/contact' },
    ]}
  />

  <!-- Trust / Quick Proof ******************* -->

  <Stats
    stats={[
      { amount: '50+', title: 'Projects delivered', icon: 'tabler:check' },
      { amount: '<48h', title: 'First response time', icon: 'tabler:rocket' },
      { amount: '100%', title: 'Clean architecture', icon: 'tabler:code' },
    ]}
  />

  <!-- What You Get ******************* -->

  <Features2
    title='What you get'
    subtitle="Everything you need for a solid Drupal platform — nothing you don't."
    columns={2}
    items={[
      {
        title: 'Custom Drupal Development',
        description:
          'Built for your exact use case. No generic setups. Content architecture that makes sense, scalable data models, multilingual & multi-site ready, built to grow without breaking.',
        icon: 'tabler:database',
      },
      {
        title: 'Twig-first Frontend',
        description:
          'No heavy JS. No hacks. Clean Twig templates with a component-based structure, modern CSS (scalable and predictable), fast by default.',
        icon: 'tabler:layout-2',
      },
      {
        title: 'Headless Drupal',
        description:
          'Drupal as backend, modern frontend on top. REST / JSON:API / GraphQL. Astro frontends. Static + dynamic where it matters. Built for performance and SEO.',
        icon: 'tabler:plug',
      },
      {
        title: 'Performance Optimization',
        description:
          'Speed is not optional. Core Web Vitals focused, lean CSS approach, smart caching (Drupal + CDN). We remove bottlenecks — not hide them.',
        icon: 'tabler:bolt',
      },
      {
        title: 'Migration & Upgrades',
        description:
          'No data loss. No chaos. Drupal 7 → 10 / 11, clean migration strategy, legacy cleanup, future-proof setup that will not need another migration in 2 years.',
        icon: 'tabler:arrows-exchange',
      },
      {
        title: 'Maintenance & Support',
        description:
          'Keep it stable. Keep it secure. Updates & patches, bug fixing, performance tuning, long-term support — we stay with you after launch.',
        icon: 'tabler:tool',
      },
    ]}
  />

  <!-- What We Build ******************* -->

  <Content
    isReversed
    title='What we build'
    subtitle='We work across industries where structured content, security, and long-term maintainability actually matter.'
    items={[
      {
        title: 'Government & Municipalities',
        description:
          'Secure, accessible public-sector websites that improve citizen engagement, transparency, and service delivery — compliant with regulatory standards.',
        icon: 'tabler:building-community',
      },
      {
        title: 'Healthcare',
        description:
          'Patient portals and healthcare websites built with data security and compliance in mind, improving accessibility for patients and efficiency for staff.',
        icon: 'tabler:heart-rate-monitor',
      },
      {
        title: 'Education',
        description:
          'Intuitive platforms for admissions, student services, and institutional communication — connecting students, parents, and faculty in one place.',
        icon: 'tabler:school',
      },
      {
        title: 'Nonprofit',
        description:
          'Donation platforms and mission-driven websites that help nonprofits reach donors, raise awareness, and amplify community impact.',
        icon: 'tabler:heart-handshake',
      },
      {
        title: 'Ecommerce',
        description:
          'High-performing, scalable stores built to maximize conversions, improve customer retention, and handle real traffic without breaking.',
        icon: 'tabler:shopping-cart',
      },
      {
        title: 'Media & Entertainment',
        description:
          'Dynamic content management systems built for scale — enabling seamless media delivery and meaningful audience engagement.',
        icon: 'tabler:device-tv',
      },
    ]}
    image={{
      src: '~/assets/images/drupal-expertise.png',
      alt: 'Drupal projects we build',
    }}
  >
    <Fragment slot='content'>
      <h3 class='text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2'>Industries we serve</h3>
    </Fragment>
  </Content>

  <!-- Process ******************* -->

  <Steps
    title='How it works'
    subtitle='A clear, predictable process — from first conversation to long-term stability.'
    tagline='Our process'
    items={[
      {
        title: 'Understand',
        description:
          'Business goals, content model, technical constraints, team setup. We ask the right questions before touching the code.',
        icon: 'tabler:zoom-question',
      },
      {
        title: 'Structure',
        description:
          'Clean Drupal architecture first. Content types, fields, relationships, and modules — planned before built, never refactored after.',
        icon: 'tabler:sitemap',
      },
      {
        title: 'Build',
        description:
          'Modular, maintainable code. Twig templates, custom modules, and third-party integrations done right — readable by the next developer.',
        icon: 'tabler:hammer',
      },
      {
        title: 'Optimize',
        description:
          'Real performance, not scores. Caching, query optimization, front-end lean — measured, profiled, and genuinely improved.',
        icon: 'tabler:gauge',
      },
      {
        title: 'Launch',
        description:
          'Stable and predictable deployment. No surprises. Environment parity, rollback plan, and a solid release process.',
        icon: 'tabler:rocket',
      },
      {
        title: 'Scale',
        description:
          'Architecture built to grow. No rebuilds later — just extending what is already solid, clean, and well-documented.',
        icon: 'tabler:trending-up',
      },
    ]}
    image={{
      src: '~/assets/images/drupal-service.png',
      alt: 'Our development process',
    }}
  />

  <!-- Stack ******************* -->

  <Features
    title='The stack'
    subtitle='Chosen for performance, maintainability, and long-term stability. No trend-chasing.'
    tagline='Technology'
    columns={3}
    items={[
      {
        title: 'Drupal 9 / 10 / 11',
        description:
          'The backbone. Enterprise-grade CMS with powerful content architecture, a mature ecosystem, and a clear upgrade path.',
        icon: 'tabler:server',
      },
      {
        title: 'Twig',
        description:
          'Clean, logic-free templating. Component-based structure that is easy to read, maintain, and hand off.',
        icon: 'tabler:code',
      },
      {
        title: 'Modern CSS (minimal JS)',
        description:
          'Scalable, predictable styles. No heavy frameworks where they are not needed. Fast by default, not by accident.',
        icon: 'tabler:palette',
      },
      {
        title: 'Astro (headless)',
        description:
          'When you need a decoupled frontend — Astro delivers fast by default, SEO-ready, and with minimal JavaScript overhead.',
        icon: 'tabler:planet',
      },
      {
        title: 'API-first approach',
        description:
          'REST, JSON:API, GraphQL. Drupal as a proper backend — interoperable, decoupled where it counts, integrated where it makes sense.',
        icon: 'tabler:plug',
      },
      {
        title: 'Git workflows',
        description:
          'Clean branching, code review, CI/CD-ready. Version control as part of the project from day one — not an afterthought.',
        icon: 'tabler:git-branch',
      },
    ]}
  />

  <!-- Why This Approach ******************* -->

  <Content
    isReversed
    title='Why this approach'
    subtitle='Most Drupal projects fail in the same places. We built our methodology around avoiding exactly those.'
    items={[
      {
        title: 'Clean architecture from day one',
        description:
          'No shortcuts in the content model or module structure. Good decisions made early prevent weeks of pain — and full rewrites — later.',
        icon: 'tabler:check',
      },
      {
        title: 'Fast by default',
        description:
          'Performance is built in, not bolted on. Lean CSS, smart caching, no bloated JS. Your site is fast before you optimise it.',
        icon: 'tabler:check',
      },
      {
        title: 'Easy to maintain',
        description:
          'Readable Twig, documented custom modules, standard patterns. Your team — or the next agency — can actually work on it.',
        icon: 'tabler:check',
      },
    ]}
    image={{
      src: '~/assets/images/drupal-hr.png',
      alt: 'Why our Drupal approach works',
    }}
  >
    <Fragment slot='content'>
      <h3 class='text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2'>The opposite of most projects</h3>
      <p class='text-muted mb-4'>Most Drupal sites suffer from the same problems:</p>
      <ul class='mb-6 space-y-2 text-muted'>
        <li class='flex items-start gap-2'>
          <span class='text-red-500 font-bold mt-0.5'>✗</span>
          Too much JavaScript everywhere — slow, fragile, hard to debug
        </li>
        <li class='flex items-start gap-2'>
          <span class='text-red-500 font-bold mt-0.5'>✗</span>
          Bad content structure that collapses under real editorial needs
        </li>
        <li class='flex items-start gap-2'>
          <span class='text-red-500 font-bold mt-0.5'>✗</span>
          Slow by default — performance hacked in after complaints
        </li>
        <li class='flex items-start gap-2'>
          <span class='text-red-500 font-bold mt-0.5'>✗</span>
          Impossible to maintain without the original developer
        </li>
      </ul>
      <p class='font-semibold text-muted'>We build the opposite:</p>
    </Fragment>
  </Content>

  <!-- Engagement Models ******************* -->

  <Features2
    title='Work with us'
    subtitle='Choose the engagement model that fits your project and team structure.'
    tagline='Engagement'
    columns={3}
    items={[
      {
        title: 'Project-based',
        description:
          'Fixed scope, clear deliverables, predictable budget. Best for well-defined projects with a clear start and end. You know what you pay before we start.',
        icon: 'tabler:file-invoice',
      },
      {
        title: 'Hourly',
        description:
          'Flexible engagement for ongoing work, audits, or when scope is not fully defined. Pay for actual time — nothing more.',
        icon: 'tabler:clock',
      },
      {
        title: 'Monthly support',
        description:
          'Dedicated hours every month for maintenance, improvements, and updates. Keep your platform stable, secure, and moving forward.',
        icon: 'tabler:calendar-stats',
      },
    ]}
  />

  <!-- Final CTA ******************* -->
  <CallToAction
    title='Ready to build something solid?'
    subtitle="No pitch decks. No pressure. Just a conversation about your project and whether we're the right fit."
    tagline="Let's talk"
    actions={[
      {
        variant: 'primary',
        text: 'Get Estimate',
        href: '/contact',
      },
      {
        text: 'Book a Call',
        href: '/contact',
      },
    ]}
  />
</Layout>
